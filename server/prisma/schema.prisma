generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROJECT_LEAD
  MEMBER
  READ_ONLY
}

enum ProjectMemberRole {
  OWNER
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  PROJECT_CREATED
  TASK_CREATED
  TASK_STATUS_CHANGED
  TASK_ASSIGNED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  TIME_LOGGED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum AccentColor {
  BLUE
  GREEN
  PURPLE
  ORANGE
  RED
  TEAL
}

enum Locale {
  EN
  ES
  FR_CA
}

model SoftwareLine {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())

  users                User[]          @relation("UserSoftwareLine")
  activeForUsers       User[]          @relation("UserActiveSoftwareLine")
  projects             Project[]
  projectTypes         ProjectType[]
  checklistItems       ChecklistItem[]
  accessRequests       AccessRequest[]
}

model User {
  id                  String      @id @default(cuid())
  name                String
  email               String      @unique
  passwordHash        String
  role                UserRole    @default(MEMBER)
  active              Boolean     @default(true)
  theme               ThemeMode   @default(SYSTEM)
  accentColor         AccentColor @default(BLUE)
  locale              Locale      @default(EN)
  softwareLineId      String
  softwareLine        SoftwareLine  @relation("UserSoftwareLine", fields: [softwareLineId], references: [id])
  activeSoftwareLineId String?
  activeSoftwareLine   SoftwareLine? @relation("UserActiveSoftwareLine", fields: [activeSoftwareLineId], references: [id])
  createdAt           DateTime    @default(now())

  createdProjects   Project[]       @relation("ProjectCreatedBy")
  projectMemberships ProjectMember[]
  createdTasks      Task[]          @relation("TaskCreatedBy")
  assignedTasks     Task[]          @relation("TaskAssignee")
  comments          Comment[]
  attachments       Attachment[]
  timeEntries       TimeEntry[]
  activities        Activity[]
  createdProjectTypes ProjectType[]
  createdSubProjects  SubProject[]
  createdChecklistItems ChecklistItem[]
  createdTaskTemplates  TaskTemplate[]
  decidedAccessRequests AccessRequest[]
}

model Project {
  id                     String      @id @default(cuid())
  name                   String
  description            String?
  teamSupportTicketNumber String?
  projectTypeId          String
  projectType            ProjectType @relation(fields: [projectTypeId], references: [id])
  softwareLineId         String
  softwareLine           SoftwareLine @relation(fields: [softwareLineId], references: [id])
  createdById            String
  createdBy              User        @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime    @default(now())
  archivedAt             DateTime?

  members    ProjectMember[]
  tasks      Task[]
  subProjects SubProject[]
  activities Activity[]
  attachments Attachment[]
}

model ProjectType {
  id             String   @id @default(cuid())
  name           String
  description    String?
  active         Boolean  @default(true)
  softwareLineId String
  softwareLine   SoftwareLine @relation(fields: [softwareLineId], references: [id])
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())

  projects Project[]
  tasks    Task[]

  @@unique([softwareLineId, name])
}

model ChecklistItem {
  id             String   @id @default(cuid())
  name           String
  description    String?
  active         Boolean  @default(true)
  softwareLineId String
  softwareLine   SoftwareLine @relation(fields: [softwareLineId], references: [id])
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())

  subProjects   SubProject[]
  taskTemplates TaskTemplate[]
}

model TaskTemplate {
  id              String        @id @default(cuid())
  checklistItemId String
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  priority        TaskPriority  @default(MEDIUM)
  active          Boolean       @default(true)
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
}

model SubProject {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklistItemId String
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id])
  name            String?
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())

  tasks Task[]
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Task {
  id            String      @id @default(cuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProjectId  String
  subProject    SubProject  @relation(fields: [subProjectId], references: [id], onDelete: Cascade)
  projectTypeId String
  projectType   ProjectType @relation(fields: [projectTypeId], references: [id])
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate     DateTime?
  completedAt DateTime?
  createdById String
  createdBy   User         @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments    Comment[]
  attachments Attachment[]
  timeEntries TimeEntry[]
  activities  Activity[]
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Attachment {
  id             String   @id @default(cuid())
  taskId         String?
  task           Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploaderId     String
  uploader       User     @relation(fields: [uploaderId], references: [id])
  storedFilename String
  originalName   String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())
}

model TimeEntry {
  id              String    @id @default(cuid())
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?
  note            String?
  createdAt       DateTime  @default(now())
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  message   String
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model AccessRequest {
  id             String              @id @default(cuid())
  name           String
  email          String
  message        String?
  status         AccessRequestStatus @default(PENDING)
  softwareLineId String
  softwareLine   SoftwareLine        @relation(fields: [softwareLineId], references: [id])
  createdAt      DateTime            @default(now())
  decidedAt      DateTime?
  decidedById    String?
  decidedBy      User?               @relation(fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([status])
}
